---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
  <!-- ═══════════════════════════════════════════════════ NAVBAR -->
  <header class="navbar">
    <div class="navbar-inner">
      <div class="navbar-brand">
        <svg
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          class="navbar-icon"
        >
          <circle cx="12" cy="8" r="4"></circle>
          <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"></path>
          <line x1="17" y1="3" x2="21" y2="7" stroke-width="1.5"></line>
          <polyline points="19 3 21 3 21 5" stroke-width="1.5"></polyline>
        </svg>
        <span class="navbar-title">Gitfolio Extractor</span>
      </div>
      <span class="navbar-badge">v1.0</span>
    </div>
  </header>

  <!-- ═══════════════════════════════════════════════════ HERO -->
  <section class="hero">
    <div class="container">
      <h1 class="hero-title">GitHub Profile → Structured JSON</h1>
      <p class="hero-subtitle">
        Extract, enrich and score any public GitHub profile with tech stack
        detection, live link discovery, and portfolio-ready output.
      </p>

      <!-- Search form -->
      <form id="search-form" class="search-form" autocomplete="off">
        <div class="search-input-wrap">
          <svg
            class="search-icon"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <circle cx="12" cy="8" r="4"></circle><path
              d="M4 20c0-4 3.6-7 8-7s8 3 8 7"></path>
          </svg>
          <input
            id="username-input"
            type="text"
            name="github_username"
            placeholder="github username"
            class="search-input"
            spellcheck="false"
            autocapitalize="none"
            required
            maxlength="39"
          />
        </div>
        <button type="submit" id="submit-btn" class="search-btn">
          <span id="btn-text">Extract Profile</span>
          <span id="btn-spinner" class="spinner" style="display:none"></span>
        </button>
      </form>

      <!-- Error banner -->
      <div id="error-banner" class="error-banner" style="display:none">
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <circle cx="12" cy="12" r="10"></circle><line
            x1="12"
            y1="8"
            x2="12"
            y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line>
        </svg>
        <span id="error-text"></span>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════ RESULTS -->
  <main class="container" id="results" style="display:none">
    <!-- Profile -->
    <section class="results-section" id="section-profile">
      <div class="section-heading">
        <span class="section-bar"></span>
        <h2 class="section-title">Profile</h2>
      </div>
      <div id="profile-slot"></div>
    </section>

    <!-- Top projects -->
    <section class="results-section" id="section-top" style="display:none">
      <div id="top-projects-slot"></div>
    </section>

    <!-- Repositories -->
    <section class="results-section" id="section-repos">
      <div class="section-heading">
        <span class="section-bar"></span>
        <h2 class="section-title">
          Repositories <span id="repo-count" class="section-count"></span>
        </h2>
        <!-- Filter bar -->
        <div class="filter-bar" id="filter-bar" style="display:none">
          <button class="filter-btn filter-btn--active" data-filter="all"
            >All</button
          >
          <button class="filter-btn" data-filter="original">Original</button>
          <button class="filter-btn" data-filter="live">Has Live Link</button>
          <button class="filter-btn" data-filter="stars">Starred</button>
        </div>
      </div>
      <div id="repos-grid" class="repos-grid"></div>
    </section>

    <!-- JSON preview -->
    <section class="results-section">
      <div class="section-heading">
        <span class="section-bar"></span>
        <h2 class="section-title">JSON Output</h2>
      </div>
      <div class="json-preview-wrap">
        <div class="json-toolbar">
          <span class="json-label">application/json</span>
          <div class="json-actions">
            <button id="btn-copy" class="json-btn" type="button">
              <svg
                width="12"
                height="12"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <rect x="9" y="9" width="13" height="13"></rect><path
                  d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"></path>
              </svg>
              Copy JSON
            </button>
            <button
              id="btn-download"
              class="json-btn json-btn--accent"
              type="button"
            >
              <svg
                width="12"
                height="12"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline><line
                  x1="12"
                  y1="15"
                  x2="12"
                  y2="3"></line>
              </svg>
              Download
            </button>
          </div>
        </div>
        <pre class="json-body" id="json-body"><code id="json-code" /></pre>
      </div>
    </section>

    <!-- ═══════════════════════════════════════ AI INSIGHTS -->
    <section class="results-section" id="section-ai">
      <div class="section-heading">
        <span class="section-bar"></span>
        <h2 class="section-title">
          <svg
            width="15"
            height="15"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
          </svg>
          AI Insights
        </h2>
        <button id="btn-ai-analyze" class="ai-btn" type="button">
          <svg
            width="13"
            height="13"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <circle cx="12" cy="12" r="3"></circle>
            <path
              d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"
            ></path>
          </svg>
          Analyze with AI
        </button>
      </div>
      <div id="ai-loading" class="ai-loading" style="display:none">
        <span class="spinner"></span>
        <span>Generating AI insights — this may take 20–40 seconds...</span>
      </div>
      <div id="ai-err" class="ai-error" style="display:none"></div>
      <div id="ai-panel" style="display:none">
        <div id="ai-visibility-slot" class="ai-subsection"></div>
        <div id="ai-ideas-slot" class="ai-subsection"></div>
        <div id="ai-metadata-slot" class="ai-subsection"></div>
        <div id="ai-contribute-slot" class="ai-subsection"></div>
      </div>
    </section>
  </main>

  <!-- ═══════════════════════════════════════════════════ FOOTER -->
  <footer class="footer">
    <div class="container">
      <span>Gitfolio Extractor — powered by the GitHub REST API</span>
    </div>
  </footer>
</BaseLayout>

<!-- ═══════════════════════════════════════════════════════════════ CLIENT SCRIPT -->
<script>
  // ── State ────────────────────────────────────────────────────────────────────
  let allRepos: any[] = [];
  let extractedData: any = null;

  // ── DOM refs ─────────────────────────────────────────────────────────────────
  const form = document.getElementById("search-form") as HTMLFormElement;
  const input = document.getElementById("username-input") as HTMLInputElement;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
  const btnText = document.getElementById("btn-text") as HTMLSpanElement;
  const btnSpinner = document.getElementById("btn-spinner") as HTMLSpanElement;
  const errorBanner = document.getElementById("error-banner") as HTMLDivElement;
  const errorText = document.getElementById("error-text") as HTMLSpanElement;
  const resultsEl = document.getElementById("results") as HTMLElement;
  const profileSlot = document.getElementById("profile-slot") as HTMLDivElement;
  const topProjectsSlot = document.getElementById(
    "top-projects-slot",
  ) as HTMLDivElement;
  const sectionTop = document.getElementById("section-top") as HTMLElement;
  const reposGrid = document.getElementById("repos-grid") as HTMLDivElement;
  const repoCount = document.getElementById("repo-count") as HTMLSpanElement;
  const filterBar = document.getElementById("filter-bar") as HTMLDivElement;
  const jsonCode = document.getElementById("json-code") as HTMLElement;
  const btnCopy = document.getElementById("btn-copy") as HTMLButtonElement;
  const btnDownload = document.getElementById(
    "btn-download",
  ) as HTMLButtonElement;

  // ── Form submit ───────────────────────────────────────────────────────────────
  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    const username = input.value.trim();
    if (!username) return;
    await runExtraction(username);
  });

  async function runExtraction(username: string) {
    setLoading(true);
    hideError();
    hideResults();

    try {
      const res = await fetch("/api/scrape", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ github_username: username }),
      });
      const data = await res.json();

      if (!res.ok) {
        showError(data.error ?? `Server error (${res.status})`);
        return;
      }

      allRepos = data.repositories ?? [];
      extractedData = data;
      renderResults(data);
    } catch (err) {
      showError("Network error — please check your connection and try again.");
    } finally {
      setLoading(false);
    }
  }

  // ── Render ────────────────────────────────────────────────────────────────────
  function renderResults(data: any) {
    renderProfile(data.profile);
    renderTopProjects(data.top_projects, data.repositories);
    renderRepos(data.repositories);
    renderJson(data);
    resultsEl.style.display = "block";
    resultsEl.scrollIntoView({ behavior: "smooth", block: "start" });
  }

  function renderProfile(p: any) {
    const website = p.website
      ? `<a href="${esc(p.website.startsWith("http") ? p.website : "https://" + p.website)}" target="_blank" rel="noopener noreferrer" class="meta-chip meta-link">
      <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
      Website</a>`
      : "";
    const twitter = p.socials?.twitter
      ? `<a href="${esc(p.socials.twitter)}" target="_blank" rel="noopener noreferrer" class="meta-chip meta-link">Twitter</a>`
      : "";
    const linkedin = p.socials?.linkedin
      ? `<a href="${esc(p.socials.linkedin)}" target="_blank" rel="noopener noreferrer" class="meta-chip meta-link">LinkedIn</a>`
      : "";
    const location = p.location
      ? `<span class="meta-chip"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>${esc(p.location)}</span>`
      : "";
    const company = p.company
      ? `<span class="meta-chip"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14"/><path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16"/></svg>${esc(p.company)}</span>`
      : "";

    profileSlot.innerHTML = `
      <div class="profile-card">
        <div class="profile-avatar-col">
          <img src="${esc(p.avatar_url)}" alt="${esc(p.username)}'s avatar" class="profile-avatar" width="88" height="88" loading="lazy" />
        </div>
        <div class="profile-info-col">
          <div class="profile-name-row">
            <span class="profile-name">${esc(p.name ?? p.username)}</span>
            <a href="https://github.com/${esc(p.username)}" target="_blank" rel="noopener noreferrer" class="profile-handle">@${esc(p.username)}</a>
          </div>
          ${p.bio ? `<p class="profile-bio">${esc(p.bio)}</p>` : ""}
          <div class="profile-meta">${location}${company}${website}${twitter}${linkedin}</div>
          <div class="profile-stats">
            <div class="stat-item"><span class="stat-value">${p.stats.public_repos}</span><span class="stat-label">Repos</span></div>
            <div class="stat-divider"></div>
            <div class="stat-item"><span class="stat-value">${p.stats.followers.toLocaleString()}</span><span class="stat-label">Followers</span></div>
            <div class="stat-divider"></div>
            <div class="stat-item"><span class="stat-value">${p.stats.following.toLocaleString()}</span><span class="stat-label">Following</span></div>
          </div>
        </div>
      </div>`;
  }

  function renderTopProjects(topProjects: string[], repositories: any[]) {
    if (!topProjects || topProjects.length === 0) {
      sectionTop.style.display = "none";
      return;
    }
    const repoMap = new Map(repositories.map((r: any) => [r.name, r]));
    const items = topProjects
      .map((name: string, i: number) => {
        const repo = repoMap.get(name) as any;
        const lang = repo?.language
          ? `<span class="top-lang">${esc(repo.language)}</span>`
          : "";
        const stars = repo
          ? `<span class="top-stars"><svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>${repo.stars}</span>`
          : "";
        return `<a href="${esc(repo?.url ?? "#")}" target="_blank" rel="noopener noreferrer" class="top-item">
        <span class="top-rank">#${i + 1}</span>
        <span class="top-name">${esc(name)}</span>
        ${lang}${stars}
      </a>`;
      })
      .join("");

    topProjectsSlot.innerHTML = `
      <div class="top-projects">
        <div class="section-heading">
          <span class="section-bar"></span>
          <h2 class="section-title">Top Projects</h2>
        </div>
        <div class="top-list">${items}</div>
      </div>`;
    sectionTop.style.display = "block";
  }

  function renderRepos(repos: any[]) {
    if (repos.length === 0) {
      reposGrid.innerHTML = `<p class="empty-state">No public repositories found.</p>`;
      filterBar.style.display = "none";
      return;
    }
    filterBar.style.display = "flex";
    repoCount.textContent = `(${repos.length})`;
    renderRepoCards(repos);
    setupFilters();
  }

  function renderRepoCards(repos: any[]) {
    const maxScore = Math.max(...repos.map((r: any) => r.importance_score), 1);
    reposGrid.innerHTML = repos
      .map((repo: any) => repoCardHtml(repo, maxScore))
      .join("");
  }

  function repoCardHtml(repo: any, maxScore: number): string {
    const scorePercent =
      maxScore > 0
        ? Math.min(100, (repo.importance_score / maxScore) * 100).toFixed(1)
        : "0";
    const date = new Date(repo.updated_at).toLocaleDateString("en-US", {
      month: "short",
      year: "numeric",
    });

    const badges = [
      repo.fork ? `<span class="badge badge-fork">fork</span>` : "",
      repo.archived ? `<span class="badge badge-archived">archived</span>` : "",
      repo.license
        ? `<span class="badge badge-license">${esc(repo.license)}</span>`
        : "",
    ].join("");

    const liveLinks = repo.live_links?.length
      ? repo.live_links
          .map(
            (l: string) =>
              `<a href="${esc(l)}" target="_blank" rel="noopener noreferrer" class="live-link-chip"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>Live</a>`,
          )
          .join("")
      : "";

    const techBadges =
      repo.tech_stack
        ?.slice(0, 10)
        .map((t: string) => `<span class="tech-badge">${esc(t)}</span>`)
        .join("") ?? "";
    const topics =
      repo.topics
        ?.slice(0, 6)
        .map((t: string) => `<span class="topic-tag">#${esc(t)}</span>`)
        .join("") ?? "";
    const langDot = repo.language
      ? `<span class="repo-stat"><span class="lang-dot"></span>${esc(repo.language)}</span>`
      : "";

    const desc = repo.clean_description ?? repo.description;

    return `
      <div class="repo-card${repo.archived ? " repo-card--archived" : ""}" data-fork="${repo.fork}" data-live="${repo.live_links?.length > 0}" data-stars="${repo.stars}">
        <div class="repo-header">
          <div class="repo-title-row">
            <a href="${esc(repo.url)}" target="_blank" rel="noopener noreferrer" class="repo-name">${esc(repo.name)}</a>
            <div class="repo-badges">${badges}</div>
          </div>
          ${desc ? `<p class="repo-desc">${esc(desc)}</p>` : ""}
        </div>
        ${liveLinks ? `<div class="repo-live-links">${liveLinks}</div>` : ""}
        ${techBadges ? `<div class="repo-tech-stack">${techBadges}</div>` : ""}
        ${topics ? `<div class="repo-topics">${topics}</div>` : ""}
        <div class="repo-footer">
          <div class="repo-stats">
            ${langDot}
            <span class="repo-stat"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>${repo.stars}</span>
            <span class="repo-stat"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="6" y1="3" x2="6" y2="15"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M18 9a9 9 0 01-9 9"/></svg>${repo.forks}</span>
            <span class="repo-stat repo-stat-date">${date}</span>
          </div>
          <div class="score-section">
            <span class="score-label">Score ${repo.importance_score}</span>
            <div class="score-bar-track"><div class="score-bar-fill" style="width:${scorePercent}%"></div></div>
          </div>
        </div>
      </div>`;
  }

  function setupFilters() {
    const btns = filterBar.querySelectorAll<HTMLButtonElement>(".filter-btn");
    btns.forEach((btn) => {
      btn.addEventListener("click", () => {
        btns.forEach((b) => b.classList.remove("filter-btn--active"));
        btn.classList.add("filter-btn--active");
        const filter = btn.dataset.filter;
        let filtered = allRepos;
        if (filter === "original") filtered = allRepos.filter((r) => !r.fork);
        else if (filter === "live")
          filtered = allRepos.filter((r) => r.live_links?.length > 0);
        else if (filter === "stars")
          filtered = allRepos.filter((r) => r.stars > 0);
        renderRepoCards(filtered);
      });
    });
  }

  function renderJson(data: any) {
    const text = JSON.stringify(data, null, 2);
    jsonCode.textContent = text;
  }

  // ── JSON buttons ──────────────────────────────────────────────────────────────
  btnCopy.addEventListener("click", async () => {
    const text = jsonCode.textContent ?? "";
    try {
      await navigator.clipboard.writeText(text);
      const orig = btnCopy.innerHTML;
      btnCopy.textContent = "Copied!";
      setTimeout(() => {
        btnCopy.innerHTML = orig;
      }, 1500);
    } catch {
      /* ignore */
    }
  });

  btnDownload.addEventListener("click", () => {
    const text = jsonCode.textContent ?? "";
    const blob = new Blob([text], { type: "application/json" });
    const url = URL.createObjectURL(blob);
    const a = document.createElement("a");
    a.href = url;
    a.download = `${input.value.trim() || "gitfolio"}.json`;
    a.click();
    URL.revokeObjectURL(url);
  });

  // ── Helpers ───────────────────────────────────────────────────────────────────
  function esc(str: string): string {
    return String(str)
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#39;");
  }

  function setLoading(on: boolean) {
    submitBtn.disabled = on;
    btnText.style.display = on ? "none" : "inline";
    btnSpinner.style.display = on ? "inline-block" : "none";
  }

  function showError(msg: string) {
    errorText.textContent = msg;
    errorBanner.style.display = "flex";
  }

  function hideError() {
    errorBanner.style.display = "none";
    errorText.textContent = "";
  }

  function hideResults() {
    resultsEl.style.display = "none";
    profileSlot.innerHTML = "";
    topProjectsSlot.innerHTML = "";
    reposGrid.innerHTML = "";
    jsonCode.textContent = "";
    // Reset AI state
    extractedData = null;
    const aiPanel = document.getElementById("ai-panel") as HTMLDivElement;
    const aiLoading = document.getElementById("ai-loading") as HTMLDivElement;
    const aiErr = document.getElementById("ai-err") as HTMLDivElement;
    const aiBtn = document.getElementById(
      "btn-ai-analyze",
    ) as HTMLButtonElement;
    if (aiPanel) {
      aiPanel.style.display = "none";
      aiPanel
        .querySelectorAll(".ai-subsection")
        .forEach((el) => ((el as HTMLElement).innerHTML = ""));
    }
    if (aiLoading) aiLoading.style.display = "none";
    if (aiErr) {
      aiErr.style.display = "none";
      aiErr.textContent = "";
    }
    if (aiBtn) {
      aiBtn.disabled = false;
    }
  }

  // ── AI Insights ───────────────────────────────────────────────────────────────
  document
    .getElementById("btn-ai-analyze")!
    .addEventListener("click", async () => {
      if (!extractedData) return;
      const aiBtn = document.getElementById(
        "btn-ai-analyze",
      ) as HTMLButtonElement;
      const aiLoading = document.getElementById("ai-loading") as HTMLDivElement;
      const aiErr = document.getElementById("ai-err") as HTMLDivElement;
      const aiPanel = document.getElementById("ai-panel") as HTMLDivElement;

      aiBtn.disabled = true;
      aiLoading.style.display = "flex";
      aiErr.style.display = "none";
      aiPanel.style.display = "none";

      try {
        const res = await fetch("/api/ai-insights", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            profile: extractedData.profile,
            repositories: extractedData.repositories,
          }),
        });
        const data = await res.json();
        if (!res.ok) {
          aiErr.textContent = data.error ?? `AI error (${res.status})`;
          aiErr.style.display = "block";
          aiBtn.disabled = false;
          return;
        }
        renderAIInsights(data);
        aiPanel.style.display = "flex";
      } catch {
        aiErr.textContent = "Network error — could not reach AI service.";
        aiErr.style.display = "block";
        aiBtn.disabled = false;
      } finally {
        aiLoading.style.display = "none";
      }
    });

  function renderAIInsights(insights: any) {
    renderVisibilityTips(insights.visibility_tips ?? []);
    renderProjectIdeas(insights.project_ideas ?? []);
    renderMetadataSuggestions(insights.metadata_suggestions ?? []);
    renderContributionTargets(insights.contribution_targets ?? []);
  }

  function renderVisibilityTips(tips: any[]) {
    const slot = document.getElementById(
      "ai-visibility-slot",
    ) as HTMLDivElement;
    if (!tips.length) {
      slot.innerHTML = "";
      return;
    }
    const cards = tips
      .map(
        (t: any) => `
      <div class="ai-tip-card priority-${esc(t.priority ?? "low")}">
        <div class="tip-meta">
          <span class="tip-repo">${esc(t.repo ?? "profile")}</span>
          <span class="tip-category">${esc(t.category ?? "")}</span>
          <span class="tip-priority">${esc(t.priority ?? "low")}</span>
        </div>
        <span class="tip-text">${esc(t.tip ?? "")}</span>
      </div>`,
      )
      .join("");
    slot.innerHTML = `
      <div class="ai-sub-heading">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
        Visibility &amp; Stars Recommendations
      </div>
      <div class="ai-tip-list">${cards}</div>`;
  }

  function renderProjectIdeas(ideas: any[]) {
    const slot = document.getElementById("ai-ideas-slot") as HTMLDivElement;
    if (!ideas.length) {
      slot.innerHTML = "";
      return;
    }
    const cards = ideas
      .map((idea: any) => {
        const tech = (idea.tech_stack ?? [])
          .map((t: string) => `<span class="tech-badge">${esc(t)}</span>`)
          .join("");
        const diffClass = `diff-${esc(idea.difficulty ?? "intermediate")}`;
        return `
        <div class="ai-idea-card">
          <span class="ai-idea-title">${esc(idea.title ?? "")}</span>
          <p class="ai-idea-desc">${esc(idea.description ?? "")}</p>
          <div class="ai-idea-why">${esc(idea.why_stars ?? "")}</div>
          <div class="ai-idea-footer">
            ${tech}
            <span class="ai-difficulty ${diffClass}">${esc(idea.difficulty ?? "")}</span>
          </div>
        </div>`;
      })
      .join("");
    slot.innerHTML = `
      <div class="ai-sub-heading">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        Project Ideas to Grow Visibility
      </div>
      <div class="ai-idea-grid">${cards}</div>`;
  }

  function renderMetadataSuggestions(suggestions: any[]) {
    const slot = document.getElementById("ai-metadata-slot") as HTMLDivElement;
    if (!suggestions.length) {
      slot.innerHTML = "";
      return;
    }
    const items = suggestions
      .map((s: any) => {
        const hasDesc = !!s.suggested_description;
        const hasTopics =
          Array.isArray(s.suggested_topics) && s.suggested_topics.length > 0;
        const badges = [
          hasDesc
            ? `<span class="ai-meta-badge ai-meta-badge--desc">description</span>`
            : "",
          hasTopics
            ? `<span class="ai-meta-badge ai-meta-badge--topic">topics</span>`
            : "",
        ].join("");
        const descHtml = hasDesc
          ? `<span class="ai-meta-desc">"${esc(s.suggested_description)}"</span>`
          : "";
        const topicsHtml = hasTopics
          ? s.suggested_topics
              .map(
                (t: string) => `<span class="ai-meta-topic">${esc(t)}</span>`,
              )
              .join("")
          : "";
        return `
        <div class="ai-meta-item">
          <div class="ai-meta-header">
            <span class="ai-meta-repo">${esc(s.repo ?? "")}</span>
            <div class="ai-meta-badges">${badges}</div>
          </div>
          ${descHtml}
          ${topicsHtml ? `<div class="ai-meta-topics">${topicsHtml}</div>` : ""}
        </div>`;
      })
      .join("");
    slot.innerHTML = `
      <div class="ai-sub-heading">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
        Suggested Descriptions &amp; Tags
      </div>
      <div class="ai-meta-list">${items}</div>`;
  }

  function renderContributionTargets(targets: any[]) {
    const slot = document.getElementById(
      "ai-contribute-slot",
    ) as HTMLDivElement;
    if (!targets.length) {
      slot.innerHTML = "";
      return;
    }
    const items = targets
      .map((t: any) => {
        const tech = (t.tech ?? [])
          .map((b: string) => `<span class="ai-contrib-badge">${esc(b)}</span>`)
          .join("");
        const gfi = t.good_first_issues
          ? `<span class="ai-good-issues">good first issues</span>`
          : "";
        return `
        <div class="ai-contrib-item">
          <div style="display:flex;align-items:center;gap:0.5rem;flex-wrap:wrap">
            <a href="${esc(t.url ?? "#")}" target="_blank" rel="noopener noreferrer" class="ai-contrib-name">${esc(t.name ?? "")}</a>
            ${gfi}
          </div>
          <p class="ai-contrib-desc">${esc(t.description ?? "")}</p>
          <p class="ai-contrib-why">${esc(t.why ?? "")}</p>
          ${tech ? `<div class="ai-contrib-tech">${tech}</div>` : ""}
        </div>`;
      })
      .join("");
    slot.innerHTML = `
      <div class="ai-sub-heading">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="18" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><path d="M6 21V9a9 9 0 009 9"/></svg>
        Open Source Projects to Contribute To
      </div>
      <div class="ai-contrib-list">${items}</div>`;
  }
</script>

