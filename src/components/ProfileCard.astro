---
export interface Props {
  profile: {
    username: string;
    name: string | null;
    bio: string | null;
    avatar_url: string;
    location: string | null;
    company: string | null;
    website: string | null;
    socials: { twitter: string | null; linkedin: string | null };
    stats: { followers: number; following: number; public_repos: number };
  };
}
const { profile } = Astro.props;
---

<div class="profile-card">
  <div class="profile-avatar-col">
    <img
      src={profile.avatar_url}
      alt={`${profile.username}'s avatar`}
      class="profile-avatar"
      width="88"
      height="88"
      loading="lazy"
    />
  </div>
  <div class="profile-info-col">
    <div class="profile-name-row">
      <span class="profile-name">{profile.name ?? profile.username}</span>
      <a
        href={`https://github.com/${profile.username}`}
        target="_blank"
        rel="noopener noreferrer"
        class="profile-handle">@{profile.username}</a
      >
    </div>
    {profile.bio && <p class="profile-bio">{profile.bio}</p>}
    <div class="profile-meta">
      {
        profile.location && (
          <span class="meta-chip">
            <svg
              width="12"
              height="12"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" />
              <circle cx="12" cy="10" r="3" />
            </svg>
            {profile.location}
          </span>
        )
      }
      {
        profile.company && (
          <span class="meta-chip">
            <svg
              width="12"
              height="12"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <rect x="2" y="7" width="20" height="14" rx="0" />
              <path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16" />
            </svg>
            {profile.company}
          </span>
        )
      }
      {
        profile.website && (
          <a
            href={
              profile.website.startsWith("http")
                ? profile.website
                : `https://${profile.website}`
            }
            target="_blank"
            rel="noopener noreferrer"
            class="meta-chip meta-link"
          >
            <svg
              width="12"
              height="12"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <circle cx="12" cy="12" r="10" />
              <line x1="2" y1="12" x2="22" y2="12" />
              <path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z" />
            </svg>
            Website
          </a>
        )
      }
      {
        profile.socials.twitter && (
          <a
            href={profile.socials.twitter}
            target="_blank"
            rel="noopener noreferrer"
            class="meta-chip meta-link"
          >
            Twitter
          </a>
        )
      }
      {
        profile.socials.linkedin && (
          <a
            href={profile.socials.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="meta-chip meta-link"
          >
            LinkedIn
          </a>
        )
      }
    </div>
    <div class="profile-stats">
      <div class="stat-item">
        <span class="stat-value">{profile.stats.public_repos}</span>
        <span class="stat-label">Repos</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-value"
          >{profile.stats.followers.toLocaleString()}</span
        >
        <span class="stat-label">Followers</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-value"
          >{profile.stats.following.toLocaleString()}</span
        >
        <span class="stat-label">Following</span>
      </div>
    </div>
  </div>
</div>

<style>
  .profile-card {
    display: flex;
    gap: 1.5rem;
    background: var(--color-base-lighter);
    border: 1px solid var(--color-border);
    border-left: 4px solid var(--color-accent);
    padding: 1.5rem;
  }

  .profile-avatar {
    display: block;
    width: 88px;
    height: 88px;
    object-fit: cover;
    border: 2px solid var(--color-border-accent);
    flex-shrink: 0;
  }

  .profile-info-col {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    min-width: 0;
  }

  .profile-name-row {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .profile-name {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-white);
  }

  .profile-handle {
    font-size: 0.875rem;
    color: var(--color-accent);
    text-decoration: none;
  }
  .profile-handle:hover {
    text-decoration: underline;
  }

  .profile-bio {
    margin: 0;
    font-size: 0.875rem;
    color: var(--color-muted);
    line-height: 1.5;
  }

  .profile-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .meta-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.75rem;
    color: var(--color-muted);
    background: var(--color-base-darker);
    border: 1px solid var(--color-border);
    padding: 0.2rem 0.5rem;
    white-space: nowrap;
  }

  .meta-link {
    color: var(--color-accent);
  }
  .meta-link:hover {
    text-decoration: underline;
  }

  .profile-stats {
    display: flex;
    align-items: center;
    gap: 0;
    background: var(--color-base-darker);
    border: 1px solid var(--color-border);
    width: fit-content;
    margin-top: 0.25rem;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0.4rem 1rem;
    gap: 0.1rem;
  }

  .stat-value {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-white);
  }

  .stat-label {
    font-size: 0.7rem;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .stat-divider {
    width: 1px;
    height: 2rem;
    background: var(--color-border);
  }

  @media (max-width: 600px) {
    .profile-card {
      flex-direction: column;
      gap: 1rem;
    }
    .profile-avatar {
      width: 64px;
      height: 64px;
    }
  }
</style>
