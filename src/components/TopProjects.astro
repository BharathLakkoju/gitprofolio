---
export interface Props {
  topProjects: string[];
  repositories: Array<{
    name: string;
    url: string;
    stars: number;
    language: string | null;
  }>;
}
const { topProjects, repositories } = Astro.props;
const repoMap = new Map(repositories.map((r) => [r.name, r]));
---

<div class="top-projects">
  <div class="section-label">
    <span class="label-bar"></span>
    Top Projects
  </div>
  <div class="top-list">
    {
      topProjects.map((name, i) => {
        const repo = repoMap.get(name);
        return (
          <a
            href={repo?.url ?? `#`}
            target="_blank"
            rel="noopener noreferrer"
            class="top-item"
          >
            <span class="top-rank">#{i + 1}</span>
            <span class="top-name">{name}</span>
            {repo?.language && <span class="top-lang">{repo.language}</span>}
            {repo !== undefined && (
              <span class="top-stars">
                <svg
                  width="11"
                  height="11"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                >
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                </svg>
                {repo.stars}
              </span>
            )}
          </a>
        );
      })
    }
  </div>
</div>

<style>
  .top-projects {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .section-label {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
  }

  .label-bar {
    display: inline-block;
    width: 3px;
    height: 16px;
    background: var(--color-accent);
  }

  .top-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .top-item {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    background: var(--color-base-lighter);
    border: 1px solid var(--color-border-accent);
    padding: 0.45rem 0.85rem;
    text-decoration: none;
    transition: background 0.15s;
  }
  .top-item:hover {
    background: rgba(59, 130, 246, 0.12);
  }

  .top-rank {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--color-accent);
  }

  .top-name {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-white);
  }

  .top-lang {
    font-size: 0.7rem;
    color: var(--color-muted);
    background: var(--color-base-darker);
    border: 1px solid var(--color-border);
    padding: 0.1rem 0.35rem;
  }

  .top-stars {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
    font-size: 0.72rem;
    color: #facc15;
    margin-left: 0.2rem;
  }

  @media (max-width: 640px) {
    .top-projects {
      padding-left: 0.5rem;
    }
    .top-list {
      gap: 0.375rem;
    }
    .top-item {
      padding: 0.4rem 0.7rem;
    }
  }
</style>
